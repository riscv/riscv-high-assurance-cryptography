digraph state_transitions {
graph [peripheries = 0];
rankdir="LR";
graph [fontname = "Petrona-Light"];
node [fontname = "Petrona-Light"];
edge [fontname = "Petrona-Light"];
subgraph G1 {
node [shape = circle,peripheries=3]; Off;
}
subgraph G2 {
  rank = same; node [shape = ellipse,peripheries=2]; AUTH_FAIL [label=<Authentication<br/>Failed>] OOM [label=<Out of Memory>] NI [label=<Not Implemented>]
  rank = same; node [shape = ellipse,peripheries=2]; PRIV_VIOL [label=<Privilege<br/>Violation>] INVALID;
  node [shape = ellipse,peripheries=1]; PARTIAL [label=<Partially<br/>Configured>];
  rank = same; node [shape = ellipse,peripheries=2]; EXPIRED;
}
subgraph G3 {
  rank = same; node [shape = ellipse,peripheries=1]; Initial;
  rank = same; node [shape = ellipse,peripheries=1]; Valid [label=<Valid<br/>(Except Success/Failure)>];
}
subgraph G6 {
  rank = same; node [shape = ellipse,peripheries=1]; Success Failure;
}

Off -> Initial [dir=both];
Off -> Valid [dir=both];
Off -> Success [dir=both];
Off -> Failure [dir=both];
Off -> OOM [dir=both];
Off -> NI [dir=both];
Off -> AUTH_FAIL [dir=both];
Off -> PRIV_VIOL [dir=both];
Off -> PARTIAL [dir=both];
Off -> INVALID [dir=both];
Off -> EXPIRED [dir=both];
Initial -> Valid;
Initial -> EXPIRED;
Initial -> PRIV_VIOL;
Valid -> Success;
Valid -> Failure;
Valid -> Valid;
Valid -> INVALID;
Valid -> EXPIRED;
Valid -> OOM;
Valid -> NI;
Valid -> PRIV_VIOL;
Success -> Initial;
Failure -> Initial;
Success -> EXPIRED;
Failure -> EXPIRED;
Success -> PRIV_VIOL;
Failure -> PRIV_VIOL;
PARTIAL -> Valid;
PARTIAL -> Success;
PARTIAL -> Failure;
}
