#
# Description:
#
# This Makefile is designed to automate the process of building and packaging
# the Doc Template for RISC-V Extensions.

DOCS := \
	ace-whitepaper.adoc

MAKE := make -f Makefile.wplocal
DATE ?= $(shell date +%Y-%m-%d)
VERSION ?= v0.5.0
REVMARK ?= Draft

SRC_DIR := src
BUILD_DIR := build

DOCS_PDF := $(DOCS:%.adoc=%.pdf)
DOCS_HTML := $(DOCS:%.adoc=%.html)

XTRA_ADOC_OPTS :=
ASCIIDOCTOR_PDF := asciidoctor-pdf
ASCIIDOCTOR_HTML := asciidoctor

OPTIONS := --trace \
           -v \
           -a compress \
           -a mathematical-format=svg \
           -a revnumber=${VERSION} \
           -a revremark=${REVMARK} \
           -a revdate=${DATE} \
           -a pdf-fontsdir=docs-resources/fonts \
           -a pdf-theme=src/wp.yml \
           $(XTRA_ADOC_OPTS) \
           -D build \
           --failure-level=ERROR

REQUIRES :=  --require=asciidoctor-lists --require=asciidoctor-bibtex

.PHONY: all build clean build-container build-no-container build-docs

all: build

build-docs: $(DOCS_PDF)

build-html: $(DOCS_HTML)

vpath %.adoc $(SRC_DIR)

%.pdf: %.adoc
	export RUBYOPT=" --zjit "
	$(ASCIIDOCTOR_PDF) $(OPTIONS) $(REQUIRES) $<

%.html: %.adoc
	export RUBYOPT=" --zjit "
	$(ASCIIDOCTOR_HTML) $(OPTIONS) $(REQUIRES) $<

build:
	$(MAKE) build-no-container;

build-no-container:
	@echo "Starting build..."
	$(MAKE) build-docs
	@echo "Build completed successfully."

# Update docker image to latest
clean:
	@echo "Cleaning up generated files..."
	rm -rf $(BUILD_DIR)
	@echo "Cleanup completed."

update-docs-resources:
	git submodule update --force --recursive --init --remote
